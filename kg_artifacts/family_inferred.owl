<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/family.owl"
         xmlns="http://example.org/family.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://example.org/family.owl"/>

<owl:ObjectProperty rdf:about="#hasParent">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#hasChild"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasChild">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#hasParent"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasAge">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasBirthYear">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasName">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Person">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#OldPerson">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:Class rdf:about="#Man">
  <rdfs:subClassOf rdf:resource="#Person"/>
  <owl:disjointWith rdf:resource="#Woman"/>
</owl:Class>

<owl:Class rdf:about="#Woman">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Alice">
  <rdf:type rdf:resource="#Woman"/>
  <hasChild rdf:resource="#Charlie"/>
  <rdf:type rdf:resource="#OldPerson"/>
  <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">65</hasAge>
  <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alice</hasName>
  <hasBirthYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1961</hasBirthYear>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Charlie">
  <rdf:type rdf:resource="#Man"/>
  <hasChild rdf:resource="#Frank"/>
  <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">45</hasAge>
  <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Charlie</hasName>
  <hasBirthYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1981</hasBirthYear>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Bob">
  <rdf:type rdf:resource="#Man"/>
  <hasChild rdf:resource="#Charlie"/>
  <rdf:type rdf:resource="#OldPerson"/>
  <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">72</hasAge>
  <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bob</hasName>
  <hasBirthYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1954</hasBirthYear>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Frank">
  <rdf:type rdf:resource="#Man"/>
  <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</hasAge>
  <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frank</hasName>
  <hasBirthYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1996</hasBirthYear>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Diana">
  <rdf:type rdf:resource="#Woman"/>
  <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">58</hasAge>
  <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diana</hasName>
  <hasBirthYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1968</hasBirthYear>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Eve">
  <rdf:type rdf:resource="#Woman"/>
  <rdf:type rdf:resource="#OldPerson"/>
  <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">80</hasAge>
  <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eve</hasName>
  <hasBirthYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1946</hasBirthYear>
</owl:NamedIndividual>

<swrl:Variable rdf:about="#p"/>

<swrl:Variable rdf:about="#age"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Person"/>
          <swrl:argument1 rdf:resource="#p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#hasAge"/>
              <swrl:argument1 rdf:resource="#p"/>
              <swrl:argument2 rdf:resource="#age"/>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:BuiltinAtom>
                  <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#greaterThan"/>
                  <swrl:arguments>
                    <rdf:Description>
                      <rdf:first rdf:resource="#age"/>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                          <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">60</rdf:first>
                        </rdf:Description>
                      </rdf:rest>
                    </rdf:Description>
                  </swrl:arguments>
                </swrl:BuiltinAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#OldPerson"/>
          <swrl:argument1 rdf:resource="#p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
