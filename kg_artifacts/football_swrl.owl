<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/hasNationality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
    <rdfs:range rdf:resource="http://example.org/Country"/>
    <rdfs:label xml:lang="en">has nationality</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/Position">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Playing Position</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/Place">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Place</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/Club">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Football Club</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/birthPlace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
    <rdfs:range rdf:resource="http://example.org/Place"/>
    <rdfs:label xml:lang="en">birth place</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Person</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heightM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:label xml:lang="en">height in meters</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/birthDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:label xml:lang="en">birth date</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/playsFor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
    <rdfs:range rdf:resource="http://example.org/Club"/>
    <rdfs:label xml:lang="en">plays for</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/FootballPlayer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/Person"/>
    <rdfs:label xml:lang="en">Football Player</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/Country">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Country</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/hasPosition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
    <rdfs:range rdf:resource="http://example.org/Position"/>
    <rdfs:label xml:lang="en">plays position</rdfs:label>
  </rdf:Description>
</rdf:RDF>
