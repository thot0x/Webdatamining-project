<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/football"
         xmlns="http://example.org/football#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#"
         xmlns:exam="http://example.org/">

<owl:Ontology rdf:about="http://example.org/football"/>

<owl:ObjectProperty rdf:about="http://example.org/playsFor">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://example.org/Club"/>
  <rdfs:label xml:lang="en">plays for</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/birthPlace">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://example.org/Place"/>
  <rdfs:label xml:lang="en">birth place</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/hasPosition">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://example.org/Position"/>
  <rdfs:label xml:lang="en">plays position</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/hasNationality">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://example.org/Country"/>
  <rdfs:label xml:lang="en">has nationality</rdfs:label>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="http://example.org/birthDate">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  <rdfs:label xml:lang="en">birth date</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://example.org/heightM">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <rdfs:label xml:lang="en">height in meters</rdfs:label>
</owl:DatatypeProperty>

<owl:Class rdf:about="http://example.org/FootballPlayer">
  <rdfs:subClassOf rdf:resource="http://example.org/Person"/>
  <rdfs:label xml:lang="en">Football Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Club">
  <rdfs:label xml:lang="en">Football Club</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Person">
  <rdfs:label xml:lang="en">Person</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Place">
  <rdfs:label xml:lang="en">Place</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Position">
  <rdfs:label xml:lang="en">Playing Position</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Country">
  <rdfs:label xml:lang="en">Country</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#Club">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#VeteranPlayer">
  <rdfs:subClassOf rdf:resource="http://example.org/FootballPlayer"/>
</owl:Class>

<owl:Class rdf:about="#YoungPlayer">
  <rdfs:subClassOf rdf:resource="http://example.org/FootballPlayer"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Cristiano_Ronaldo">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#VeteranPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1985-02-05</exam:birthDate>
  <rdfs:label xml:lang="en">Cristiano Ronaldo</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Al_Nassr">
  <rdf:type rdf:resource="#Club"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Lionel_Messi">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#VeteranPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1987-06-24</exam:birthDate>
  <rdfs:label xml:lang="en">Lionel Messi</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Inter_Miami">
  <rdf:type rdf:resource="#Club"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Luka_Modric">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#VeteranPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1985-09-09</exam:birthDate>
  <rdfs:label xml:lang="en">Luka Modric</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Real_Madrid">
  <rdf:type rdf:resource="#Club"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kylian_Mbappe">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#YoungPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1998-12-20</exam:birthDate>
  <rdfs:label xml:lang="en">Kylian Mbappe</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Vinicius_Jr">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#YoungPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2000-07-12</exam:birthDate>
  <rdfs:label xml:lang="en">Vinicius Jr</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Erling_Haaland">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#YoungPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2000-07-21</exam:birthDate>
  <rdfs:label xml:lang="en">Erling Haaland</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Man_City">
  <rdf:type rdf:resource="#Club"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Xavi_Hernandez">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#VeteranPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1980-01-25</exam:birthDate>
  <rdfs:label xml:lang="en">Xavi Hernandez</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Al_Sadd">
  <rdf:type rdf:resource="#Club"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Iker_Casillas">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#VeteranPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1981-05-20</exam:birthDate>
  <rdfs:label xml:lang="en">Iker Casillas</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Retired">
  <rdf:type rdf:resource="#Club"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Thierry_Henry">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#VeteranPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1977-08-17</exam:birthDate>
  <rdfs:label xml:lang="en">Thierry Henry</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Zinedine_Zidane">
  <rdf:type rdf:resource="http://example.org/FootballPlayer"/>
  <rdf:type rdf:resource="#VeteranPlayer"/>
  <exam:birthDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1972-06-23</exam:birthDate>
  <rdfs:label xml:lang="en">Zinedine Zidane</rdfs:label>
</owl:NamedIndividual>

<swrl:Variable rdf:about="#p"/>

<swrl:Variable rdf:about="#d"/>

<swrl:Variable rdf:about="#p2"/>

<swrl:Variable rdf:about="#d2"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="http://example.org/FootballPlayer"/>
          <swrl:argument1 rdf:resource="#p2"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="http://example.org/birthDate"/>
              <swrl:argument1 rdf:resource="#p2"/>
              <swrl:argument2 rdf:resource="#d2"/>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:BuiltinAtom>
                  <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#greaterThanOrEqual"/>
                  <swrl:arguments>
                    <rdf:Description>
                      <rdf:first rdf:resource="#d2"/>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                          <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1990-01-01</rdf:first>
                        </rdf:Description>
                      </rdf:rest>
                    </rdf:Description>
                  </swrl:arguments>
                </swrl:BuiltinAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#YoungPlayer"/>
          <swrl:argument1 rdf:resource="#p2"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="http://example.org/FootballPlayer"/>
          <swrl:argument1 rdf:resource="#p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="http://example.org/birthDate"/>
              <swrl:argument1 rdf:resource="#p"/>
              <swrl:argument2 rdf:resource="#d"/>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:BuiltinAtom>
                  <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#lessThan"/>
                  <swrl:arguments>
                    <rdf:Description>
                      <rdf:first rdf:resource="#d"/>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                          <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1990-01-01</rdf:first>
                        </rdf:Description>
                      </rdf:rest>
                    </rdf:Description>
                  </swrl:arguments>
                </swrl:BuiltinAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#VeteranPlayer"/>
          <swrl:argument1 rdf:resource="#p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
