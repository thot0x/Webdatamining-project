<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/football"
         xmlns="http://example.org/football#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://example.org/football"/>

<owl:ObjectProperty rdf:about="http://example.org/hasNationality">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://example.org/Country"/>
  <rdfs:label xml:lang="en">has nationality</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/birthPlace">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://example.org/Place"/>
  <rdfs:label xml:lang="en">birth place</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/playsFor">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://example.org/Club"/>
  <rdfs:label xml:lang="en">plays for</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/hasPosition">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://example.org/Position"/>
  <rdfs:label xml:lang="en">plays position</rdfs:label>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="http://example.org/heightM">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <rdfs:label xml:lang="en">height in meters</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://example.org/birthDate">
  <rdfs:domain rdf:resource="http://example.org/FootballPlayer"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  <rdfs:label xml:lang="en">birth date</rdfs:label>
</owl:DatatypeProperty>

<owl:Class rdf:about="http://example.org/FootballPlayer">
  <rdfs:subClassOf rdf:resource="http://example.org/Person"/>
  <rdfs:label xml:lang="en">Football Player</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Country">
  <rdfs:label xml:lang="en">Country</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Position">
  <rdfs:label xml:lang="en">Playing Position</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Place">
  <rdfs:label xml:lang="en">Place</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Club">
  <rdfs:label xml:lang="en">Football Club</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/Person">
  <rdfs:label xml:lang="en">Person</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#VeteranPlayer">
  <rdfs:subClassOf rdf:resource="http://example.org/FootballPlayer"/>
</owl:Class>

<owl:Class rdf:about="#YoungPlayer">
  <rdfs:subClassOf rdf:resource="http://example.org/FootballPlayer"/>
</owl:Class>

<swrl:Variable rdf:about="#p"/>

<swrl:Variable rdf:about="#d"/>

<swrl:Variable rdf:about="#p2"/>

<swrl:Variable rdf:about="#d2"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="http://example.org/FootballPlayer"/>
          <swrl:argument1 rdf:resource="#p2"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="http://example.org/birthDate"/>
              <swrl:argument1 rdf:resource="#p2"/>
              <swrl:argument2 rdf:resource="#d2"/>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:BuiltinAtom>
                  <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#greaterThanOrEqual"/>
                  <swrl:arguments>
                    <rdf:Description>
                      <rdf:first rdf:resource="#d2"/>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                          <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1990-01-01</rdf:first>
                        </rdf:Description>
                      </rdf:rest>
                    </rdf:Description>
                  </swrl:arguments>
                </swrl:BuiltinAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#YoungPlayer"/>
          <swrl:argument1 rdf:resource="#p2"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="http://example.org/FootballPlayer"/>
          <swrl:argument1 rdf:resource="#p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="http://example.org/birthDate"/>
              <swrl:argument1 rdf:resource="#p"/>
              <swrl:argument2 rdf:resource="#d"/>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:BuiltinAtom>
                  <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#lessThan"/>
                  <swrl:arguments>
                    <rdf:Description>
                      <rdf:first rdf:resource="#d"/>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                          <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1990-01-01</rdf:first>
                        </rdf:Description>
                      </rdf:rest>
                    </rdf:Description>
                  </swrl:arguments>
                </swrl:BuiltinAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#VeteranPlayer"/>
          <swrl:argument1 rdf:resource="#p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
